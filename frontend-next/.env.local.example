# ============================================
# Lender.cr Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values

# Backend API (server-side, internal Docker network)
API_URL=http://backend:8000

# Backend API (client-side, browser access)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Site URL
NEXT_PUBLIC_SITE_URL=https://lender.cr

# Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Google Ads
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_ADS_CONVERSION_LABEL_LEAD=
NEXT_PUBLIC_ADS_CONVERSION_LABEL_CONTACT=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
